# Normalize line endings: store text as LF in the repo. CRLF in a Windows
# checkout is the most common source of noisy cross-OS diffs here.
* text=auto eol=lf

# Windows scripts must keep CRLF or they break when run.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets — never normalize line endings or attempt text diffs.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.pdf   binary

# Generated / vendored — collapse diffs and exclude from language stats.
pnpm-lock.yaml       linguist-generated=true -diff
src-tauri/Cargo.lock  linguist-generated=true
src-tauri/gen/**      linguist-generated=true

# graphify generated graph artifacts — collapse diffs, exclude from language stats.
graphify-out/graph.json  linguist-generated=true -diff
graphify-out/graph.html  linguist-generated=true -diff
