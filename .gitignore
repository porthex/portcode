# deps
node_modules
# build output
dist
dist-ssr
web-dist
# rust
src-tauri/target
# Workspace build output. Phase 1 of docs/IOS_WEB_CLIENT_PLAN.md turned the repo
# into a Cargo workspace, so cargo now writes a shared `target/` at the repo root
# (the per-crate `src-tauri/target` above is kept for any legacy/standalone build).
/target
# env / secrets
.env
.env.local
*.local
# editor
.vscode/*
!.vscode/extensions.json
.idea
# Nimbalyst editor local working data (plans, session artifacts)
nimbalyst-local/
# os
Thumbs.db
.DS_Store
# test / coverage output
coverage
*.lcov
# tool caches
.vite
.eslintcache
# SBOM + signing artifacts (release process). NEVER commit signing material.
# CycloneDX SBOMs
*.cdx.json
*.spdx.json
# Authenticode / Azure Trusted Signing material
*.pfx
*.snk
*.cer
*.crt
# Tauri updater signing keys (`tauri signer generate`) — private key is a secret
*.key
*.key.pub
# Generated updater + release artifacts (produced in CI, uploaded to Releases)
*.sig
latest.json
# NSIS / bundle output lives under src-tauri/target (already ignored above);
# this is a belt-and-suspenders guard in case bundles are copied to the root.
/bundle/
# graphify knowledge graph — https://github.com/safishamsi/graphify
# The graph (graphify-out/graph.json, graph.html, GRAPH_REPORT.md) is meant to be
# committed so the whole team shares one map; only these local-only / machine-
# specific bits are ignored. To opt out of committing the graph entirely, replace
# this block with a single line: graphify-out/
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/.graphify_*.json
graphify-out/.needs_update
graphify-out/cost.json
graphify-out/cache/
graphify-out/memory/
# `graphify update` snapshots the prior graph into a dated backup dir before each
# rebuild — local history, never committed.
graphify-out/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/

# Generated knowledge graph - regenerate locally; not committed (it can embed doc content)
graphify-out/

# ruflo / claude-flow agent state — local, machine-specific tooling artifacts (never committed)
.swarm/
.hive-mind/
.claude-flow/
ruvector.db
ruvector.db-*
