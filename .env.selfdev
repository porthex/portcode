# Self-dev build channel marker.
#
# Loaded by Vite when running in `selfdev` mode (the `*:self` pnpm scripts).
# Surfaced to the UI as a small "DEV" pill so the self-dev build is visually
# distinct from your everyday Portcode — they keep SEPARATE history & settings.
#
# Safe to commit: this is a build-channel flag, not a secret. (Vite only exposes
# vars prefixed with `VITE_` to the client bundle.)
VITE_PORTCODE_CHANNEL=dev
