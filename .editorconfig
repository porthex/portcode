# EditorConfig — https://editorconfig.org
# Keeps editors aligned with rustfmt (4-space Rust) and Prettier (2-space
# web), with LF endings and a trailing newline so editors don't fight CI.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.rs]
indent_size = 4

[*.md]
# Trailing whitespace is significant in Markdown (hard line break).
trim_trailing_whitespace = false

[*.{bat,cmd,ps1}]
# Windows scripts must stay CRLF (see .gitattributes).
end_of_line = crlf

[Makefile]
indent_style = tab
