{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Portcode Dev",
  "identifier": "dev.porthex.portcode.dev",
  "build": {
    "beforeDevCommand": "pnpm dev:self",
    "beforeBuildCommand": "pnpm build:self"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Portcode Dev",
        "width": 1200,
        "height": 800,
        "minWidth": 760,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark"
      }
    ]
  }
}
