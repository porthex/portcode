{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Portcode",
  "version": "5.0.0",
  "identifier": "dev.porthex.portcode",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:if-needed"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Portcode",
        "width": 1200,
        "height": 800,
        "minWidth": 760,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/porthex/portcode/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFNTAzQUVBOTFENEIyNjEKUldSaHN0U1I2anBRSHVGV0JycFd3eCtaVHdFU1FrUFEyRFhRdTB4N2Z5Z0d6NTBJRXpreDlYN0cK"
    }
  }
}
